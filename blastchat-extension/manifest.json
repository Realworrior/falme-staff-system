{
  "manifest_version": 3,
  "name": "BlastChat Matrix",
  "version": "1.1",
  "description": "Auto-populates responses directly into BlastChat agent views.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://blastchat.chat/*",
    "https://*.blastchat.chat/*",
    "https://kgpcruwlejoougjbeouw.supabase.co/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BlastChat Matrix",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://blastchat.chat/*",
        "https://*.blastchat.chat/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ]
}
