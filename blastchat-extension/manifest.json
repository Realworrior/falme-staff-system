{
  "manifest_version": 3,
  "name": "BlastChat Quick Responses",
  "version": "1.0",
  "description": "Auto-populates responses directly into BlastChat agent views.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://blastchat.chat/*",
    "https://*.blastchat.chat/*",
    "https://kgpcruwlejoougjbeouw.supabase.co/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BlastChat Tools",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://blastchat.chat/*",
        "https://*.blastchat.chat/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
